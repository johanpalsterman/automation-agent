# ══════════════════════════════════════════════════
#  .env.example — OpenClaw + Paperclip Desktop
#  Kopieer dit bestand naar .env en vul de waarden in
# ══════════════════════════════════════════════════

# ── LLM Provider ─────────────────────────────────
# Kies je AI provider: anthropic (standaard), openai, groq, mistral, bedrock
LLM_PROVIDER=anthropic

# Jouw API key voor de gekozen provider
# - Anthropic: https://console.anthropic.com/
# - OpenAI:    https://platform.openai.com/api-keys
# - Groq:      https://console.groq.com/keys
# - Mistral:   https://console.mistral.ai/api-keys
LLM_API_KEY=your-api-key-here

# ── AWS Bedrock (alleen bij LLM_PROVIDER=bedrock) ─
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_REGION=us-east-1
# BEDROCK_MODEL=bedrock/anthropic.claude-3-haiku-20240307-v1:0

# ── OpenClaw Gateway ─────────────────────────────
# Poort waarop OpenClaw luistert (standaard: 5000)
OPENCLAW_PORT=5000

# Beveiligingstoken voor de gateway (verander dit naar iets unieks!)
OPENCLAW_TOKEN=openclaw-desktop-secret

# ── Paperclip ────────────────────────────────────
# Poort waarop Paperclip luistert (standaard: 3001)
PAPERCLIP_PORT=3001

# ── Replit-specifiek (alleen op Replit, niet op desktop) ─
# Deze worden automatisch ingesteld door Replit zelf:
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=  (auto via Replit Anthropic integratie)
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=  (auto via Replit)
# REPLIT_DEV_DOMAIN=                   (auto door Replit)

# ── Optionele kanalen ────────────────────────────
# Telegram bot token (via @BotFather op Telegram)
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord bot token (via https://discord.com/developers/applications)
# DISCORD_BOT_TOKEN=your-discord-bot-token
